NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only Supabase key for username/password registration. Never expose this as NEXT_PUBLIC_*.
SUPABASE_SECRET_KEY=

# GuitarHub chatbot talks directly to Hermes Agent API Server on the VPS.
# Example URL: http://YOUR_VPS_IP:8642 or https://yoda-api.your-domain.com
HERMES_API_URL=
HERMES_API_KEY=
HERMES_API_MODEL=hermes-agent
