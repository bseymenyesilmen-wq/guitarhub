NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: AI chatbot provider. If empty, chatbot still gives safe GuitarHub navigation replies.
# Supports OpenAI-compatible /chat/completions endpoints.
AI_CHAT_API_KEY=
AI_CHAT_API_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini

# Comma-separated emails allowed as admin-mode users in chatbot.
# Public users are limited to GuitarHub/site/guitar help.
CHATBOT_ADMIN_EMAILS=
